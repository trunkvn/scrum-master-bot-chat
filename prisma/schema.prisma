generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Team Members ───
model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  firstName  String
  role       String   @default("member") // "admin" | "member"
  createdAt  DateTime @default(now())

  // Relations
  assignedCards Card[]    @relation("CardAssignee")
  comments      Comment[]
  boards        Board[]   @relation("BoardOwner")

  @@index([telegramId])
}

// ─── Project Boards ───
model Board {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  chatId      String?  // Linked Telegram group chat ID
  topicId     String?  // Linked Telegram Topic ID (message_thread_id)
  ownerId     Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner  User    @relation("BoardOwner", fields: [ownerId], references: [id])
  lists  List[]
  labels Label[]

  @@unique([chatId])
}

// ─── Lists (Columns: To Do, In Progress, Done, etc.) ───
model List {
  id        Int      @id @default(autoincrement())
  name      String
  position  Int      @default(0)
  boardId   Int
  createdAt DateTime @default(now())

  // Relations
  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

// ─── Cards (Individual Tasks) ───
model Card {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.Text
  position    Int       @default(0)
  priority    String    @default("medium") // "low" | "medium" | "high" | "urgent"
  dueDate     DateTime?
  displayId   Int?
  listId      Int
  assigneeId  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  list     List        @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee User?       @relation("CardAssignee", fields: [assigneeId], references: [id])
  labels   CardLabel[]
  comments Comment[]

  @@index([listId])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([displayId])
}

// ─── Labels ───
model Label {
  id      Int    @id @default(autoincrement())
  name    String
  color   String @default("blue") // "red" | "blue" | "green" | "yellow" | "purple" | "orange"
  boardId Int

  // Relations
  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
}

// ─── Card ↔ Label (Many-to-Many) ───
model CardLabel {
  cardId  Int
  labelId Int

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

// ─── Comments / Activity ───
model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  cardId    Int
  authorId  Int
  createdAt DateTime @default(now())

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([cardId])
}